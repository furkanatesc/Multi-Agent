# LLM API Keys
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# LangSmith Tracing
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=multi-agent-mobile-dev

# Database and Cache
# Production uses PostgresSaver checkpointing. Development can fall back to memory.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/multi_agent_db
REDIS_URL=redis://localhost:6379/0

# Integrations
GITHUB_TOKEN=your_github_personal_access_token_here
DOCKER_HOST=npipe:////./pipe/docker_engine # For Windows, use unix:///var/run/docker.sock for Linux/macOS
